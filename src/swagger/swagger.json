{
  "openapi": "3.0.0",
  "info": {
    "title": "Flora API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/bouquets": {
      "get": {
        "summary": "Get all bouquets",
        "responses": {
          "200": { "description": "List of bouquets" }
        }
      },
      "post": {
        "summary": "Create bouquet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BouquetCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Bouquet created" },
          "400": { "description": "Bad Request" }
        }
      }
    },
    "/api/bouquets/{id}": {
      "get": {
        "summary": "Get bouquet by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Bouquet found" },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "summary": "Update bouquet",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BouquetUpdate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Bouquet updated" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "summary": "Delete bouquet",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Bouquet deleted" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/bouquets/{id}/favorite": {
      "patch": {
        "summary": "Update favorite status",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BouquetFavorite" }
            }
          }
        },
        "responses": {
          "200": { "description": "Favorite updated" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/bouquets/{id}/photo": {
      "patch": {
        "summary": "Update bouquet photo",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["photo"],
                "properties": {
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Photo updated" },
          "400": { "description": "Photo is required" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/reviews": {
      "get": {
        "summary": "Get all reviews",
        "responses": {
          "200": { "description": "List of reviews" }
        }
      },
      "post": {
        "summary": "Create review",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReviewCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Review created" },
          "400": { "description": "Bad Request" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BouquetCreate": {
        "type": "object",
        "required": ["title", "price"],
        "properties": {
          "photoURL": { "type": "string", "example": "https://example.com/rose.jpg" },
          "title": { "type": "string", "example": "Red Roses" },
          "description": { "type": "string", "example": "Fresh red roses bouquet" },
          "price": { "type": "number", "example": 1200 },
          "favorite": { "type": "boolean", "example": false }
        }
      },
      "BouquetUpdate": {
        "type": "object",
        "properties": {
          "photoURL": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "favorite": { "type": "boolean" }
        }
      },
      "BouquetFavorite": {
        "type": "object",
        "required": ["favorite"],
        "properties": {
          "favorite": { "type": "boolean", "example": true }
        }
      },
      "ReviewCreate": {
        "type": "object",
        "required": ["author", "rating", "comment"],
        "properties": {
          "author": { "type": "string", "example": "Igor" },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5, "example": 5 },
          "comment": { "type": "string", "example": "Very beautiful flowers!" }
        }
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "author": { "type": "string", "example": "Igor" },
          "rating": { "type": "integer", "example": 5 },
          "comment": { "type": "string", "example": "Very beautiful flowers!" },
          "createdAt": { "type": "string", "example": "2026-07-06T23:36:31.960Z" },
          "updatedAt": { "type": "string", "example": "2026-07-06T23:36:31.960Z" }
        }
      }
    }
  }
}